# 복사해서 .env.local 로 사용하세요. 발급 절차는 SETUP.md 참고.

# Auth.js 세션 암호화 키 (필수) — 생성: npx auth secret 또는
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Kakao OAuth — https://developers.kakao.com
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# TossPayments — https://developers.tosspayments.com (미설정 시 공개 샌드박스 키 사용)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
